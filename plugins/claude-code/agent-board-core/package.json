{
  "name": "agent-board-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "agent-board local server + executor + UI (vendored inside plugin)",
  "main": "server.mjs",
  "bin": {
    "agentboard": "./bin/agentboard.mjs"
  },
  "scripts": {
    "start": "node --experimental-sqlite server.mjs",
    "build:ui": "cd ui && vite build",
    "typecheck": "tsc --noEmit -p src/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "commander": "^14.0.3",
    "liquidjs": "^10.25.7",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
