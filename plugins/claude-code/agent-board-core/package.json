{
  "name": "agent-board-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "agent-board local server + executor + UI (vendored inside plugin)",
  "main": "server.ts",
  "bin": {
    "agentboard": "./bin/agentboard.ts"
  },
  "scripts": {
    "start": "node --experimental-sqlite server.ts",
    "build": "npm run typecheck && npm run build:ui",
    "build:ui": "cd ui && vite build",
    "typecheck": "tsc --noEmit -p src/tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks || true"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "@github/copilot-sdk": "^0.3.0",
    "commander": "^14.0.3",
    "liquidjs": "^10.25.7",
    "pino": "^10.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-x": "^4.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.14.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
